NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=genetics

APP_HOST=0.0.0.0
APP_PORT=8000

GNN_MODEL_PATH=ml/models/gnn_model.pt
GNN_EMBEDDING_DIM=128
GNN_HIDDEN_DIM=256
GNN_NUM_LAYERS=3
GNN_DROPOUT=0.3
GNN_LEARNING_RATE=0.001
GNN_BATCH_SIZE=256
GNN_EPOCHS=100

RESIDUAL_ALPHA=0.1
LAYER_NORM_EPS=1e-5
GRADIENT_CLIP_NORM=5.0
LABEL_SMOOTHING=0.1
NAN_PATIENCE=3

SAMPLING_ENABLED=True
SAMPLING_NUM_NEIGHBORS=[10,8,5]
SAMPLING_DEGREE_THRESHOLD=50
SAMPLING_RANDOM_WALK_LENGTH=3
SAMPLING_RANDOM_WALK_ITERATIONS=10
SAMPLING_INFERENCE_BATCH_SIZE=512

INCREMENTAL_TRAIN_INTERVAL=3600
INCREMENTAL_TRAIN_ENABLED=True
INCREMENTAL_BATCH_SIZE=1000

DATA_DIR=data
LOG_LEVEL=INFO
